# =============================================================================
# AMS Wiki — 환경 변수 설정
# =============================================================================
# 이 파일을 .env 로 복사한 후 값을 채워주세요.
# cp .env.example .env

# =============================================================================
# Supabase (필수 — DB + Auth)
# =============================================================================
# Supabase 프로젝트 URL  (예: https://abcdefg.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon key (공개 키)
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# Confluence API (선택 — 이미지 프록시 + 검색 연동)
# =============================================================================
# 클라이언트 빌드에 포함되는 키 (Vite가 VITE_ 접두사만 노출)
VITE_CONFLUENCE_EMAIL=
VITE_CONFLUENCE_TOKEN=
VITE_CONFLUENCE_DOMAIN=hiconsy.atlassian.net
VITE_CONFLUENCE_SPACE_KEY=FVSOL

# 서버 사이드 전용 (Vercel Serverless Function: api/confluence-img).
# 이 값이 있으면 prod 환경에서도 Confluence 첨부 이미지가 정상 노출됩니다.
# 로컬 vite dev 서버는 vite.config.js 가 VITE_CONFLUENCE_* 를 재사용하므로 별도 설정 불필요.
CONFLUENCE_EMAIL=
CONFLUENCE_TOKEN=
CONFLUENCE_DOMAIN=hiconsy.atlassian.net

# =============================================================================
# 앱 설정
# =============================================================================
VITE_ENV=development
VITE_API_BASE_URL=http://localhost:5173
