# =============================================================================
# AMS Wiki — 환경 변수 설정
# =============================================================================
# 이 파일을 .env 로 복사한 후 값을 채워주세요.
# cp .env.example .env

# =============================================================================
# Supabase (필수 — DB + Auth)
# =============================================================================
# Supabase 프로젝트 URL  (예: https://abcdefg.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon key (공개 키)
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# Confluence API (선택 — 이미지 프록시 + 검색 연동)
# =============================================================================
VITE_CONFLUENCE_EMAIL=
VITE_CONFLUENCE_TOKEN=
VITE_CONFLUENCE_DOMAIN=hiconsy.atlassian.net
VITE_CONFLUENCE_SPACE_KEY=FVSOL

# =============================================================================
# 앱 설정
# =============================================================================
VITE_ENV=development
VITE_API_BASE_URL=http://localhost:5173
