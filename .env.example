# =============================================================================
# Confluence API Configuration
# =============================================================================
# Email used for Confluence authentication
VITE_CONFLUENCE_EMAIL=your-email@example.com

# Confluence API token
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
VITE_CONFLUENCE_TOKEN=your-api-token-here

# Optional: Confluence domain (if using custom domain)
# VITE_CONFLUENCE_DOMAIN=your-domain.atlassian.net

# =============================================================================
# Application Settings
# =============================================================================
# Environment: development, staging, or production
VITE_ENV=development

# Enable analytics and monitoring
VITE_ENABLE_ANALYTICS=true

# =============================================================================
# API Configuration
# =============================================================================
# Base URL for API requests
# Development: http://localhost:5173
# Production: https://sdij-ams-wiki.app
VITE_API_BASE_URL=http://localhost:5173

# =============================================================================
# Supabase (Vercel 통합 — store_BE2CoXO5hUhEkxhK)
# Vercel 대시보드에서 자동 주입됨. 로컬 개발 시 직접 설정 필요.
# 설정 없을 경우 mockData fallback 사용.
# =============================================================================
# Project URL: Vercel Supabase 통합 > Connection 탭에서 확인
VITE_SUPABASE_URL=

# Anon public key: Supabase 대시보드 > Project Settings > API
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# GitHub & Vercel CI/CD
# =============================================================================
# These are set automatically in GitHub Actions and Vercel:
# - VERCEL_TOKEN: Used for Vercel deployments
# - VERCEL_ORG_ID: Vercel organization ID
# - VERCEL_PROJECT_ID: Vercel project ID
