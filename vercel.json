{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "ignoreCommand": "git log --oneline -1 --pretty=%B | grep -q 'skip vercel' && echo 1 || echo 0",
  "git": {
    "deploymentEnabled": {
      "main": false,
      "claude/*": true
    }
  },
  "buildCache": {
    "enabled": true
  }
}
