{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "ignoreCommand": "git log --format=%B -1 | grep -q 'skip vercel'",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "claude/*": true
    }
  }
}
